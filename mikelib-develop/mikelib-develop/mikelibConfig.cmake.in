@PACKAGE_INIT@

set(_MIKELIB_supported_components "shared" "static")

if(MIKELIB_FIND_COMPONENTS)
    foreach(_comp ${MIKELIB_FIND_COMPONENTS})
        if(NOT _comp IN_LIST _MIKELIB_supported_components)
            set(MIKELIB_FOUND False)
            set(MIKELIB_NOT_FOUND_MESSAGE "Unsupported component: ${_comp}")
        endif(NOT _comp IN_LIST _MIKELIB_supported_components)

        include("${CMAKE_CURRENT_LIST_DIR}/MIKELIB-${_comp}.cmake")
    endforeach(_comp ${MIKELIB_FIND_COMPONENTS})
else(MIKELIB_FIND_COMPONENTS)
    foreach(_component_config IN LISTS _MIKELIB_supported_components)
        include("${CMAKE_CURRENT_LIST_DIR}/MIKELIB-${_component_config}.cmake")
    endforeach(_component_config IN LISTS _MIKELIB_supported_components)
endif(MIKELIB_FIND_COMPONENTS)
